# Optional project-local model config. Real keys stay in `.env.local`
# or `/Users/<you>/.config/ai-providers/env.local`.

# SACCADE_LLM_PROVIDER controls which backend generates the highlight map.
# - "auto"   (default): use a real LLM when a key is configured, otherwise fall back to the deterministic mock.
# - "mock":   always use the deterministic mock algorithm (no network).
# - "minimax": force the real MiniMax (Anthropic-compatible) provider; errors if no key is configured.
SACCADE_LLM_PROVIDER=auto

# Real provider keys (leave empty to use the mock).
MINIMAX_TOKEN_PLAN_KEY=
MINIMAX_API_KEY=

# Real provider endpoint and model. The defaults below work for the
# MiniMax Anthropic-compatible service.
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M3

# TillGlance fallback (optional)
TILLGLANCE_API_URL=https://api.tillglance.com/nlphl
# TILLGLANCE_API_KEY=            # 当前公开 endpoint 不需要，预留
